{
  "name": "@siren/sdk",
  "version": "0.1.0",
  "description": "Official Siren SDK for Node.js and TypeScript — affiliate and incentive tracking for any commerce stack.",
  "keywords": [
    "siren",
    "affiliate",
    "affiliate-marketing",
    "referral",
    "referral-program",
    "incentives",
    "rewards",
    "sdk",
    "typescript",
    "nodejs",
    "webhooks",
    "ecommerce",
    "stripe"
  ],
  "homepage": "https://sirenaffiliates.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Novatorius/siren-node.git"
  },
  "bugs": {
    "url": "https://github.com/Novatorius/siren-node/issues"
  },
  "author": "Novatorius",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "openapi.yaml"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
